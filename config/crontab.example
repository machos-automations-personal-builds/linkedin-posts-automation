# Macho's Content Engine - Cron Schedule
# All times are in America/Chicago (CT). DST is handled automatically.
#
# To install: run `crontab -e` and paste these lines.
# Replace /path/to/linkedin-posts-automation with your actual repo path.
# Replace /path/to/venv with your actual virtual environment path.

TZ=America/Chicago

# Weekly research scan — Sunday at 6:00am CT
0 6 * * 0 cd /path/to/linkedin-posts-automation && /path/to/venv/bin/python research/scanner.py >> logs/scanner.log 2>&1

# Draft generation — Monday and Thursday at 8:00am CT
0 8 * * 1,4 cd /path/to/linkedin-posts-automation && /path/to/venv/bin/python generator/draft.py >> logs/draft.log 2>&1

# Post scheduler — every 30 minutes
*/30 * * * * cd /path/to/linkedin-posts-automation && /path/to/venv/bin/python scheduler/poster.py >> logs/poster.log 2>&1

# Daily health check — 7:00am CT
0 7 * * * cd /path/to/linkedin-posts-automation && /path/to/venv/bin/python scripts/health_check.py >> logs/health.log 2>&1
