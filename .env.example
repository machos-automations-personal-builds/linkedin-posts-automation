# ==========================================
# Macho's Content Engine - Environment Variables
# ==========================================

# ------------------------------------------
# Application Settings
# ------------------------------------------
# Set to 'true' ONLY after staging validation is complete.
# When 'false', posts are written to a log file instead of LinkedIn.
PRODUCTION_MODE=false

# ------------------------------------------
# LLM API Keys
# ------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here  # Fallback if using GPT-4

# ------------------------------------------
# LinkedIn API Credentials
# ------------------------------------------
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_ACCESS_TOKEN=your_linkedin_oauth_access_token
LINKEDIN_PERSON_URN=urn:li:person:your_person_id

# ------------------------------------------
# Mattermost Notifications
# ------------------------------------------
MATTERMOST_WEBHOOK_URL=your_mattermost_incoming_webhook_url

# ------------------------------------------
# UI (for Mattermost draft links)
# ------------------------------------------
UI_URL=http://localhost:5000/review

# ------------------------------------------
# Database
# ------------------------------------------
DB_PATH=db/queue.db

# ------------------------------------------
# Research overrides (optional; else use config/*.txt)
# ------------------------------------------
# KEYWORDS=AI automation,small business operations
# REDDIT_SUBREDDITS=entrepreneur,smallbusiness,automation,artificial
# NEWSLETTER_RSS_FEEDS=https://example.com/feed.xml
# RESEARCH_SOURCES=google_news,reddit,hacker_news,newsletter_rss

# ------------------------------------------
# Blog publishing (on_publish.py, triggered by the Hub)
# ------------------------------------------
# Number of LinkedIn promo draft variations to generate per published post.
# BLOG_PROMO_VARIATION_COUNT=3
